APP_NAME=Bellhop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Host ports used by docker-compose.yml
APP_PORT=8080
MAILPIT_WEB_PORT=8025

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bellhop
DB_USERNAME=bellhop
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@bellhop.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe test/sandbox mode — register a free account, no business
# verification needed to use test-mode keys. STRIPE_KEY is the
# publishable key (pk_test_...), STRIPE_SECRET is the secret key
# (sk_test_...), both from the Stripe dashboard. STRIPE_WEBHOOK_SECRET
# comes from `stripe listen --forward-to localhost:8080/webhooks/stripe`
# for local dev (see CLAUDE.md).
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Frankfurter (exchange rates, Settings page + booking-time currency
# conversion) — free, keyless, no signup needed. Only override if you're
# pointing at a self-hosted/mirrored instance.
# FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1

# Seeded accounts (see database/seeders/RoleAndDemoUserSeeder.php).
# super-admin is never exposed via the login-as switcher.
DEMO_LOGIN_ENABLED=true

# Monthly wipe-and-regenerate of demo guests/bookings (see
# app/Console/Commands/ReseedDemoActivity.php) — off switch for a
# genuinely destructive scheduled operation.
DEMO_RESEED_ACTIVITY_ENABLED=true

SUPER_ADMIN_EMAIL=super.admin@bellhop.test
SUPER_ADMIN_PASSWORD=

DEMO_ADMIN_EMAIL=admin@bellhop.test
DEMO_ADMIN_PASSWORD=

DEMO_STAFF_EMAIL=staff@bellhop.test
DEMO_STAFF_PASSWORD=

DEMO_GUEST_EMAIL=guest@bellhop.test
DEMO_GUEST_PASSWORD=
