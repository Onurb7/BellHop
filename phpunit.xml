<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <!-- All test env overrides (APP_ENV, DB_CONNECTION/DB_DATABASE,
         STRIPE_WEBHOOK_SECRET, etc.) live in tests/bootstrap.php, not
         here — PHPUnit's <env> tags don't reliably override a variable
         docker-compose has already baked into the container's real OS
         environment (see the comment in tests/bootstrap.php). -->
</phpunit>
